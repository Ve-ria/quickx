{
  "name": "@amethyst-labs/quickx",
  "version": "2.1.0",
  "description": "Codex profile switcher with a Commander CLI and Ink TUI",
  "keywords": [
    "codex",
    "cli",
    "ink",
    "react",
    "openai"
  ],
  "homepage": "https://github.com/Ve-ria/quickx",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ve-ria/quickx.git"
  },
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "bin": "./dist/index.mjs",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "dev": "tsx src/index.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^6",
    "js-yaml": "^4.1.1",
    "react": "^19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24",
    "@types/react": "^19",
    "eslint": "^10.2.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
