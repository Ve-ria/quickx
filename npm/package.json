{
  "name": "@amethyst-labs/quickcli",
  "version": "2.0.0-beta.7",
  "description": "Switch AI coding assistant providers (Claude Code, Codex, OpenCode) with one command",
  "keywords": [
    "ai",
    "codex",
    "claude",
    "cli",
    "provider"
  ],
  "homepage": "https://github.com/AmethystDev-Labs/QuickCLI",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmethystDev-Labs/QuickCLI.git"
  },
  "dependencies": {
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "node-gyp": "^11.2.0"
  },
  "optionalDependencies": {
    "@amethyst-labs/quickcli-darwin-arm64": "2.0.0-beta.7",
    "@amethyst-labs/quickcli-darwin-x64": "2.0.0-beta.7",
    "@amethyst-labs/quickcli-linux-arm64": "2.0.0-beta.7",
    "@amethyst-labs/quickcli-linux-x64": "2.0.0-beta.7",
    "@amethyst-labs/quickcli-win32-x64": "2.0.0-beta.7"
  },
  "scripts": {
    "build:artifacts": "node scripts/build-platform-artifacts.js",
    "postinstall": "node scripts/postinstall.js",
    "prepare:platform": "node scripts/prepare-platform-package.js",
    "sync:platform-deps": "node scripts/set-platform-deps-version.js",
    "stage:platform": "node scripts/stage-platform-package.js"
  },
  "bin": {
    "quick": "./bin/quick.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md"
  ],
  "engines": {
    "node": ">=16"
  }
}
